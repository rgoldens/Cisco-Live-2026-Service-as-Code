          <mxGeometry x="0" y="0" width="1100" height="450" as="geometry" />
        </mxCell>

        <!-- Breadcrumb -->
        <mxCell id="breadcrumb" parent="1" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fontColor=#00aaff;" value="&lt;font color=&quot;#00aaff&quot;&gt;LTRATO-1001&lt;/font&gt;&lt;font color=&quot;#5a6a7a&quot;&gt; | &lt;/font&gt;&lt;font color=&quot;#00aaff&quot;&gt;Service Insertion as Code: From Concept to Commit&lt;/font&gt;" vertex="1">
          <mxGeometry x="25" y="12" width="350" height="20" as="geometry" />
        </mxCell>

        <!-- Title -->
