<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io" type="device">
  <diagram name="Deriving an IS-IS NET Address" id="isis-net-derivation">
    <mxGraphModel dx="1100" dy="450" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="450" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;font style=&quot;font-size:20px;&quot;&gt;&lt;b&gt;Deriving an IS-IS NET Address&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="350" height="35" as="geometry"/>
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="step1_box" value="&lt;font style=&quot;font-size:11px;&quot;&gt;&lt;b&gt;Step 1&lt;/b&gt;&lt;br&gt;Start with Loopback0 IP&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="65" width="170" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="step1_val" value="&lt;font face=&quot;Courier New&quot; style=&quot;font-size:16px;&quot; color=&quot;#1B5E20&quot;&gt;&lt;b&gt;192.168.20.21&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" vertex="1" parent="1">
          <mxGeometry x="30" y="125" width="170" height="30" as="geometry"/>
        </mxCell>

        <!-- Arrow 1-2 -->
        <mxCell id="arrow12" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="200" y="92" as="sourcePoint"/>
            <mxPoint x="250" y="92" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="step2_box" value="&lt;font style=&quot;font-size:11px;&quot;&gt;&lt;b&gt;Step 2&lt;/b&gt;&lt;br&gt;Pad each octet to 3 digits&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="65" width="180" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="step2_val" value="&lt;font face=&quot;Courier New&quot; style=&quot;font-size:16px;&quot; color=&quot;#1B5E20&quot;&gt;&lt;b&gt;192.168.020.021&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" vertex="1" parent="1">
          <mxGeometry x="250" y="125" width="180" height="30" as="geometry"/>
        </mxCell>

        <!-- Arrow 2-3 -->
        <mxCell id="arrow23" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="430" y="92" as="sourcePoint"/>
            <mxPoint x="480" y="92" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="step3_box" value="&lt;font style=&quot;font-size:11px;&quot;&gt;&lt;b&gt;Step 3&lt;/b&gt;&lt;br&gt;Remove dots, regroup&lt;br&gt;into 4-digit pairs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="60" width="180" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="step3_val" value="&lt;font face=&quot;Courier New&quot; style=&quot;font-size:16px;&quot; color=&quot;#1B5E20&quot;&gt;&lt;b&gt;1921.6802.0021&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" vertex="1" parent="1">
          <mxGeometry x="480" y="130" width="180" height="30" as="geometry"/>
        </mxCell>

        <!-- Arrow 3-4 -->
        <mxCell id="arrow34" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="660" y="92" as="sourcePoint"/>
            <mxPoint x="710" y="92" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Step 4 -->
        <mxCell id="step4_box" value="&lt;font style=&quot;font-size:11px;&quot;&gt;&lt;b&gt;Step 4&lt;/b&gt;&lt;br&gt;Add area prefix + suffix&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#1B5E20;strokeWidth=2;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="710" y="65" width="180" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="step4_val" value="&lt;font face=&quot;Courier New&quot; style=&quot;font-size:13px;&quot; color=&quot;#1B5E20&quot;&gt;&lt;b&gt;49.0002.1921.6802.0021.00&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" vertex="1" parent="1">
          <mxGeometry x="690" y="125" width="220" height="30" as="geometry"/>
        </mxCell>

        <!-- Final result highlight -->
        <mxCell id="result_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1B5E20;strokeWidth=3;arcSize=15;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="685" y="120" width="230" height="40" as="geometry"/>
        </mxCell>

        <!-- Breakdown section -->
        <mxCell id="breakdown_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F8E9;strokeColor=#689F38;strokeWidth=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="190" width="940" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="breakdown_title" value="&lt;font style=&quot;font-size:14px;&quot;&gt;&lt;b&gt;NET Address Breakdown&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" vertex="1" parent="1">
          <mxGeometry x="400" y="195" width="220" height="30" as="geometry"/>
        </mxCell>

        <!-- Full NET display -->
        <mxCell id="net_full" value="&lt;font face=&quot;Courier New&quot; style=&quot;font-size:22px;&quot;&gt;&lt;b&gt;49&lt;/b&gt;.&lt;b&gt;0002&lt;/b&gt;.&lt;b&gt;1921&lt;/b&gt;.&lt;b&gt;6802&lt;/b&gt;.&lt;b&gt;0021&lt;/b&gt;.&lt;b&gt;00&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" vertex="1" parent="1">
          <mxGeometry x="270" y="230" width="500" height="35" as="geometry"/>
        </mxCell>

        <!-- Bracket lines and labels for each part -->

        <!-- AFI: 49 -->
        <mxCell id="afi_bracket" value="" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#D32F2F;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="310" y="265" as="sourcePoint"/>
            <mxPoint x="340" y="265" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="afi_line" value="" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#D32F2F;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="325" y="265" as="sourcePoint"/>
            <mxPoint x="325" y="290" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="afi_label" value="&lt;font style=&quot;font-size:13px;&quot; color=&quot;#D32F2F&quot;&gt;&lt;b&gt;49&lt;/b&gt;&lt;br&gt;AFI (private)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#D32F2F;fontSize=12;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="295" width="130" height="50" as="geometry"/>
        </mxCell>

        <!-- Area ID: 0002 -->
        <mxCell id="area_bracket" value="" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#E65100;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="355" y="265" as="sourcePoint"/>
            <mxPoint x="415" y="265" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="area_line" value="" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#E65100;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="385" y="265" as="sourcePoint"/>
            <mxPoint x="385" y="290" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="area_label" value="&lt;font style=&quot;font-size:13px;&quot; color=&quot;#E65100&quot;&gt;&lt;b&gt;0002&lt;/b&gt;&lt;br&gt;Area ID&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=12;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="415" y="295" width="130" height="50" as="geometry"/>
        </mxCell>

        <!-- System ID: 1921.6802.0021 -->
        <mxCell id="sysid_bracket" value="" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#1565C0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="430" y="265" as="sourcePoint"/>
            <mxPoint x="645" y="265" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="sysid_line" value="" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#1565C0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="537" y="265" as="sourcePoint"/>
            <mxPoint x="537" y="290" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="sysid_label" value="&lt;font style=&quot;font-size:13px;&quot; color=&quot;#1565C0&quot;&gt;&lt;b&gt;1921.6802.0021&lt;/b&gt;&lt;br&gt;System ID (from IP)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=12;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="570" y="295" width="190" height="50" as="geometry"/>
        </mxCell>

        <!-- SEL: 00 -->
        <mxCell id="sel_bracket" value="" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#6A1B9A;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="660" y="265" as="sourcePoint"/>
            <mxPoint x="695" y="265" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="sel_line" value="" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#6A1B9A;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="678" y="265" as="sourcePoint"/>
            <mxPoint x="678" y="290" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="sel_label" value="&lt;font style=&quot;font-size:13px;&quot; color=&quot;#6A1B9A&quot;&gt;&lt;b&gt;00&lt;/b&gt;&lt;br&gt;SEL (always 00)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;fontSize=12;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="785" y="295" width="150" height="50" as="geometry"/>
        </mxCell>

        <!-- Connecting lines from breakdown labels to brackets -->
        <mxCell id="afi_connect" style="endArrow=block;endFill=1;html=1;strokeWidth=1;strokeColor=#D32F2F;exitX=0.5;exitY=0;exitDx=0;exitDy=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="325" y="295" as="sourcePoint"/>
            <mxPoint x="325" y="290" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
