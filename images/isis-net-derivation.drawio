        <mxCell id="div2" parent="1" style="endArrow=none;html=1;strokeColor=#00d4ff;strokeWidth=1;" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="25" y="72" as="sourcePoint" />
            <mxPoint x="1075" y="72" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step boxes -->
        <mxCell id="step1_box" value="&lt;font color=&quot;#00cc66&quot;&gt;&lt;b&gt;Step 1&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#c8d0d8&quot;&gt;Start with Loopback0 IP&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e2d3d;strokeColor=#00cc66;strokeWidth=2;arcSize=20;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="85" width="170" height="55" as="geometry"/>
