<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io" type="device">
  <diagram name="How Ansible Works" id="ansible-workflow">
    <mxGraphModel dx="1100" dy="500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;font style=&quot;font-size:20px;&quot;&gt;&lt;b&gt;How Ansible Works&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="15" width="260" height="35" as="geometry"/>
        </mxCell>

        <!-- Playbook Box -->
        <mxCell id="playbook" value="&lt;b&gt;Playbook&lt;br&gt;(YAML)&lt;/b&gt;" style="shape=document;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;size=0.15;" vertex="1" parent="1">
          <mxGeometry x="40" y="140" width="130" height="100" as="geometry"/>
        </mxCell>

        <!-- Arrow: reads -->
        <mxCell id="arrow_reads" value="&lt;b&gt;reads&lt;/b&gt;" style="endArrow=block;endFill=1;html=1;fontSize=11;strokeWidth=2;strokeColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="playbook" target="engine">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Ansible Engine Box -->
        <mxCell id="engine" value="&lt;font style=&quot;font-size:16px;&quot;&gt;&lt;b&gt;Ansible&lt;br&gt;Engine&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B3D4F0;strokeColor=#2171B5;fontColor=#000000;fontSize=16;arcSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="110" width="200" height="160" as="geometry"/>
        </mxCell>

        <!-- Control Node label -->
        <mxCell id="control_label" value="&lt;i&gt;Control Node (dCloud Server)&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="305" y="280" width="190" height="30" as="geometry"/>
        </mxCell>

        <!-- SSH Arrows -->
        <mxCell id="arrow_ssh1" value="&lt;b&gt;SSH&lt;/b&gt;" style="endArrow=block;endFill=1;html=1;fontSize=10;strokeWidth=2;strokeColor=#666666;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.2;exitDx=0;exitDy=0;" edge="1" parent="1" source="engine" target="nxos">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_ssh2" value="&lt;b&gt;SSH&lt;/b&gt;" style="endArrow=block;endFill=1;html=1;fontSize=10;strokeWidth=2;strokeColor=#666666;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.4;exitDx=0;exitDy=0;" edge="1" parent="1" source="engine" target="iosxe">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_ssh3" value="&lt;b&gt;SSH&lt;/b&gt;" style="endArrow=block;endFill=1;html=1;fontSize=10;strokeWidth=2;strokeColor=#666666;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.6;exitDx=0;exitDy=0;" edge="1" parent="1" source="engine" target="iosxr">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_ssh4" value="&lt;b&gt;SSH&lt;/b&gt;" style="endArrow=block;endFill=1;html=1;fontSize=10;strokeWidth=2;strokeColor=#666666;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.8;exitDx=0;exitDy=0;" edge="1" parent="1" source="engine" target="linux">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Device Boxes -->
        <mxCell id="nxos" value="&lt;b&gt;NX-OS&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;n9k-ce01, n9k-ce02&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="660" y="80" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="iosxe" value="&lt;b&gt;IOS-XE&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;csr-pe01, csr-pe02&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="660" y="145" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="iosxr" value="&lt;b&gt;IOS-XR&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;xrd01, xrd02&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="660" y="210" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="linux" value="&lt;b&gt;Linux&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;client1-4&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="660" y="275" width="200" height="50" as="geometry"/>
        </mxCell>

        <!-- Managed Devices label -->
        <mxCell id="managed_label" value="&lt;i&gt;Managed Devices (10 nodes)&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="690" y="335" width="160" height="30" as="geometry"/>
        </mxCell>

        <!-- Key callout -->
        <mxCell id="callout" value="&lt;font style=&quot;font-size:12px;&quot;&gt;&#x1f511; &lt;b&gt;No agents installed on devices&lt;/b&gt; — Ansible connects via SSH&lt;/font&gt;" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;size=20;position=0.5;base=15;fillColor=#FFF3CD;strokeColor=#D6A800;fontSize=12;rounded=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="380" width="500" height="60" as="geometry"/>
        </mxCell>

        <!-- Grouping bracket for devices -->
        <mxCell id="device_bracket" value="" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;flipH=1;size=0.5;strokeColor=#999999;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="80" width="15" height="245" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
