        </mxCell>
        <mxCell id="vars_header" value="&lt;font face=&quot;Courier New&quot; color=&quot;#ff8800&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;vars:&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];" vertex="1" parent="1">
          <mxGeometry x="110" y="220" width="60" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="vars_content" value="&lt;font face=&quot;Courier New&quot; color=&quot;#c8d0d8&quot; style=&quot;font-size:11px;&quot;&gt;vlans:&lt;br&gt;&amp;nbsp;&amp;nbsp;- name: &lt;font color=&quot;#00cc66&quot;&gt;ENGINEERING&lt;/font&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;vlan_id: &lt;font color=&quot;#00d4ff&quot;&gt;100&lt;/font&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;enabled: &lt;font color=&quot;#00cc66&quot;&gt;true&lt;/font&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;- name: &lt;font color=&quot;#00cc66&quot;&gt;MARKETING&lt;/font&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;vlan_id: &lt;font color=&quot;#00d4ff&quot;&gt;200&lt;/font&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="130" y="245" width="300" height="95" as="geometry"/>
        </mxCell>

        <!-- Callout: vars -->
        <mxCell id="callout_vars" value="&lt;font style=&quot;font-size:12px;&quot; color=&quot;#ff8800&quot;&gt;&lt;b&gt;DATA&lt;/b&gt; &amp;mdash; you edit this!&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2a1e00;strokeColor=#ff8800;fontSize=12;arcSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="250" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_vars" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#ff8800;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="callout_vars">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="270" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- TASKS Section -->
        <mxCell id="tasks_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0e2a1e;strokeColor=#00cc66;strokeWidth=2;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="100" y="360" width="500" height="205" as="geometry"/>
        </mxCell>
        <mxCell id="tasks_header" value="&lt;font face=&quot;Courier New&quot; color=&quot;#00cc66&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;tasks:&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];" vertex="1" parent="1">
          <mxGeometry x="110" y="365" width="70" height="25" as="geometry"/>
        </mxCell>

        <!-- Callout: tasks -->
        <mxCell id="callout_tasks" value="&lt;font style=&quot;font-size:12px;&quot; color=&quot;#00cc66&quot;&gt;&lt;b&gt;LOGIC&lt;/b&gt; &amp;mdash; already&lt;br&gt;written for you&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0e2a1e;strokeColor=#00cc66;fontSize=12;arcSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="360" width="190" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_tasks" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#00cc66;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="callout_tasks">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="382" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Single task inside tasks -->
        <mxCell id="task_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141e2b;strokeColor=#00cc66;strokeWidth=1;dashed=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="395" width="460" height="160" as="geometry"/>
        </mxCell>

        <!-- name line -->
        <mxCell id="task_name" value="&lt;font face=&quot;Courier New&quot; color=&quot;#c8d0d8&quot; style=&quot;font-size:11px;&quot;&gt;- name: &lt;b&gt;&lt;font color=&quot;#ffffff&quot;&gt;Configure VLANs on NX-OS switches&lt;/font&gt;&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="135" y="405" width="380" height="22" as="geometry"/>
        </mxCell>
