<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io" type="device">
  <diagram name="Anatomy of an Ansible Playbook" id="playbook-anatomy">
    <mxGraphModel dx="1100" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;font style=&quot;font-size:20px;&quot;&gt;&lt;b&gt;Anatomy of an Ansible Playbook&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="10" width="370" height="35" as="geometry"/>
        </mxCell>

        <!-- Outer playbook file box -->
        <mxCell id="playbook_file" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=2;dashed=1;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="60" y="55" width="580" height="520" as="geometry"/>
        </mxCell>
        <mxCell id="playbook_file_label" value="&lt;font style=&quot;font-size:13px;&quot; face=&quot;Courier New&quot;&gt;&lt;b&gt;deploy_vlans.yml&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="58" width="160" height="25" as="geometry"/>
        </mxCell>

        <!-- PLAY section -->
        <mxCell id="play_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;strokeWidth=2;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="80" y="90" width="540" height="475" as="geometry"/>
        </mxCell>
        <mxCell id="play_label" value="&lt;font face=&quot;Courier New&quot; style=&quot;font-size:14px;&quot;&gt;&lt;b&gt;PLAY&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];" vertex="1" parent="1">
          <mxGeometry x="90" y="95" width="60" height="25" as="geometry"/>
        </mxCell>

        <!-- Callout: Play -->
        <mxCell id="callout_play" value="&lt;font style=&quot;font-size:11px;&quot;&gt;&lt;b&gt;PLAY&lt;/b&gt; &amp;mdash; Targets a&lt;br&gt;group of devices&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="85" width="160" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_play" style="endArrow=block;endFill=1;html=1;strokeWidth=1.5;strokeColor=#1565C0;entryX=1;entryY=0.05;entryDx=0;entryDy=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="callout_play" target="play_box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- hosts line -->
        <mxCell id="hosts_line" value="&lt;font face=&quot;Courier New&quot; style=&quot;font-size:12px;&quot;&gt;hosts: &lt;b&gt;nxos&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="110" y="125" width="140" height="25" as="geometry"/>
        </mxCell>
        <!-- Callout: hosts -->
        <mxCell id="callout_hosts" value="&lt;font style=&quot;font-size:11px;&quot;&gt;Which devices&lt;br&gt;from &lt;b&gt;inventory&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="140" width="140" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_hosts" style="endArrow=block;endFill=1;html=1;strokeWidth=1.5;strokeColor=#1565C0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="callout_hosts">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="250" y="137" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- gather_facts line -->
        <mxCell id="gather_line" value="&lt;font face=&quot;Courier New&quot; style=&quot;font-size:12px;&quot;&gt;gather_facts: false&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="110" y="150" width="180" height="25" as="geometry"/>
        </mxCell>

        <!-- VARS Section (yellow) -->
        <mxCell id="vars_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=2;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="185" width="500" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="vars_header" value="&lt;font face=&quot;Courier New&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;vars:&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];" vertex="1" parent="1">
          <mxGeometry x="110" y="190" width="60" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="vars_content" value="&lt;font face=&quot;Courier New&quot; style=&quot;font-size:11px;&quot;&gt;vlans:&lt;br&gt;&amp;nbsp;&amp;nbsp;- name: ENGINEERING&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;vlan_id: 100&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;enabled: true&lt;br&gt;&amp;nbsp;&amp;nbsp;- name: MARKETING&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;vlan_id: 200&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="130" y="215" width="300" height="95" as="geometry"/>
        </mxCell>

        <!-- Callout: vars -->
        <mxCell id="callout_vars" value="&lt;font style=&quot;font-size:12px;&quot; color=&quot;#E65100&quot;&gt;&lt;b&gt;DATA&lt;/b&gt; &amp;mdash; you edit this!&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=12;arcSize=20;shadow=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="220" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_vars" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#E65100;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="callout_vars">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="240" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- TASKS Section (light blue) -->
        <mxCell id="tasks_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;strokeWidth=2;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="100" y="330" width="500" height="225" as="geometry"/>
        </mxCell>
        <mxCell id="tasks_header" value="&lt;font face=&quot;Courier New&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;tasks:&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];" vertex="1" parent="1">
          <mxGeometry x="110" y="335" width="70" height="25" as="geometry"/>
        </mxCell>

        <!-- Callout: tasks -->
        <mxCell id="callout_tasks" value="&lt;font style=&quot;font-size:12px;&quot; color=&quot;#01579B&quot;&gt;&lt;b&gt;LOGIC&lt;/b&gt; &amp;mdash; already&lt;br&gt;written for you&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#01579B;fontSize=12;arcSize=20;shadow=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="330" width="190" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_tasks" style="endArrow=block;endFill=1;html=1;strokeWidth=2;strokeColor=#01579B;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="callout_tasks">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="352" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Single task inside tasks -->
        <mxCell id="task_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0288D1;strokeWidth=1;dashed=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="365" width="460" height="175" as="geometry"/>
        </mxCell>

        <!-- name line -->
        <mxCell id="task_name" value="&lt;font face=&quot;Courier New&quot; style=&quot;font-size:11px;&quot;&gt;- name: &lt;b&gt;Configure VLANs on NX-OS switches&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="135" y="375" width="380" height="22" as="geometry"/>
        </mxCell>
        <!-- Callout: name -->
        <mxCell id="callout_name" value="&lt;font style=&quot;font-size:10px;&quot;&gt;Human-readable&lt;br&gt;description&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=10;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="395" width="120" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_name" style="endArrow=block;endFill=1;html=1;strokeWidth=1.5;strokeColor=#7B1FA2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="callout_name">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="515" y="386" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- module line -->
        <mxCell id="task_module" value="&lt;font face=&quot;Courier New&quot; style=&quot;font-size:11px;&quot;&gt;&amp;nbsp;&amp;nbsp;&lt;b&gt;cisco.nxos.nxos_vlans:&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];fillColor=#E8F5E9;strokeColor=#43A047;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="135" y="400" width="230" height="25" as="geometry"/>
        </mxCell>
        <!-- Callout: module -->
        <mxCell id="callout_module" value="&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b&gt;Module&lt;/b&gt; (the plugin)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=10;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="445" width="130" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_module" style="endArrow=block;endFill=1;html=1;strokeWidth=1.5;strokeColor=#2E7D32;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="callout_module">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="365" y="412" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- config/state lines -->
        <mxCell id="task_config" value="&lt;font face=&quot;Courier New&quot; style=&quot;font-size:11px;&quot;&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;config:&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;- name: &lt;b&gt;&quot;{{ item.name }}&quot;&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;vlan_id: &lt;b&gt;{{ item.vlan_id }}&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;enabled: &lt;b&gt;{{ item.enabled }}&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;state: merged&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="135" y="430" width="350" height="90" as="geometry"/>
        </mxCell>

        <!-- Highlight on {{ variable }} -->
        <mxCell id="var_highlight" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#D84315;strokeWidth=2;dashed=1;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="260" y="445" width="200" height="55" as="geometry"/>
        </mxCell>

        <!-- Callout: variable -->
        <mxCell id="callout_var" value="&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b&gt;{{ variable }}&lt;/b&gt;&lt;br&gt;Variable substitution&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBE9E7;strokeColor=#D84315;fontSize=10;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="490" width="150" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_var" style="endArrow=block;endFill=1;html=1;strokeWidth=1.5;strokeColor=#D84315;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="callout_var">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="460" y="472" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
