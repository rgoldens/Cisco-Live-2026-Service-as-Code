        <mxCell id="callout_name" value="&lt;font style=&quot;font-size:10px;&quot; color=&quot;#cc88ff&quot;&gt;Human-readable&lt;br&gt;description&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e1e2e;strokeColor=#cc88ff;fontSize=10;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="740" y="420" width="120" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_name" style="endArrow=block;endFill=1;html=1;strokeWidth=1.5;strokeColor=#cc88ff;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="callout_name">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="515" y="416" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- module line -->
        <mxCell id="task_module" value="&lt;font face=&quot;Courier New&quot; color=&quot;#c8d0d8&quot; style=&quot;font-size:11px;&quot;&gt;&amp;nbsp;&amp;nbsp;&lt;b&gt;&lt;font color=&quot;#00cc66&quot;&gt;cisco.nxos.nxos_vlans:&lt;/font&gt;&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];fillColor=#0e2a1e;strokeColor=#00cc66;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="135" y="430" width="230" height="25" as="geometry"/>
        </mxCell>
        <!-- Callout: module -->
        <mxCell id="callout_module" value="&lt;font style=&quot;font-size:10px;&quot; color=&quot;#00cc66&quot;&gt;&lt;b&gt;Module&lt;/b&gt; (the plugin)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0e2a1e;strokeColor=#00cc66;fontSize=10;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="740" y="470" width="130" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_module" style="endArrow=block;endFill=1;html=1;strokeWidth=1.5;strokeColor=#00cc66;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="callout_module">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="365" y="442" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- config/state lines -->
        <mxCell id="task_config" value="&lt;font face=&quot;Courier New&quot; color=&quot;#c8d0d8&quot; style=&quot;font-size:11px;&quot;&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;config:&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;- name: &lt;font color=&quot;#ff8800&quot;&gt;&lt;b&gt;&quot;{{ item.name }}&quot;&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;vlan_id: &lt;font color=&quot;#ff8800&quot;&gt;&lt;b&gt;{{ item.vlan_id }}&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;enabled: &lt;font color=&quot;#ff8800&quot;&gt;&lt;b&gt;{{ item.enabled }}&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;state: &lt;font color=&quot;#00d4ff&quot;&gt;merged&lt;/font&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="135" y="460" width="350" height="90" as="geometry"/>
        </mxCell>

        <!-- Highlight on {{ variable }} -->
        <mxCell id="var_highlight" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#ff4444;strokeWidth=2;dashed=1;arcSize=15;" vertex="1" parent="1">
