<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io" type="device">
  <diagram name="Anatomy of an Ansible Playbook" id="playbook-anatomy">
    <mxGraphModel dx="1100" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Slide background -->
        <mxCell id="bg" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0e1621;strokeColor=none;" value="" vertex="1">
          <mxGeometry x="0" y="0" width="1100" height="600" as="geometry" />
        </mxCell>

        <!-- Breadcrumb -->
        <mxCell id="breadcrumb" parent="1" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fontColor=#00aaff;" value="&lt;font color=&quot;#00aaff&quot;&gt;LTRATO-1001&lt;/font&gt;&lt;font color=&quot;#5a6a7a&quot;&gt; | &lt;/font&gt;&lt;font color=&quot;#00aaff&quot;&gt;Service Insertion as Code: From Concept to Commit&lt;/font&gt;" vertex="1">
          <mxGeometry x="25" y="12" width="350" height="20" as="geometry" />
        </mxCell>

        <!-- Title -->
        <mxCell id="title" parent="1" style="text;html=1;fontSize=20;fontStyle=1;align=left;verticalAlign=middle;fontColor=#ffffff;" value="Anatomy of an Ansible Playbook" vertex="1">
          <mxGeometry x="25" y="30" width="500" height="35" as="geometry" />
        </mxCell>

        <!-- Dual-line divider -->
        <mxCell id="div1" parent="1" style="endArrow=none;html=1;strokeColor=#00aaff;strokeWidth=3;" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="25" y="66" as="sourcePoint" />
            <mxPoint x="1075" y="66" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="div2" parent="1" style="endArrow=none;html=1;strokeColor=#00d4ff;strokeWidth=1;" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="25" y="72" as="sourcePoint" />
            <mxPoint x="1075" y="72" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Outer playbook file box -->
        <mxCell id="playbook_file" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141e2b;strokeColor=#5a6a7a;strokeWidth=2;dashed=1;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="60" y="85" width="580" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="playbook_file_label" value="&lt;font face=&quot;Courier New&quot; color=&quot;#00d4ff&quot; style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;deploy_vlans.yml&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="88" width="160" height="25" as="geometry"/>
        </mxCell>

        <!-- PLAY section -->
        <mxCell id="play_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e2d3d;strokeColor=#00aaff;strokeWidth=2;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="540" height="455" as="geometry"/>
        </mxCell>
        <mxCell id="play_label" value="&lt;font face=&quot;Courier New&quot; color=&quot;#00aaff&quot; style=&quot;font-size:14px;&quot;&gt;&lt;b&gt;PLAY&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];" vertex="1" parent="1">
          <mxGeometry x="90" y="125" width="60" height="25" as="geometry"/>
        </mxCell>

        <!-- Callout: Play -->
        <mxCell id="callout_play" value="&lt;font style=&quot;font-size:11px;&quot; color=&quot;#ffffff&quot;&gt;&lt;b&gt;PLAY&lt;/b&gt; &amp;mdash; Targets a&lt;br&gt;group of devices&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e2d3d;strokeColor=#00aaff;fontSize=11;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="740" y="115" width="160" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_play" style="endArrow=block;endFill=1;html=1;strokeWidth=1.5;strokeColor=#00aaff;entryX=1;entryY=0.05;entryDx=0;entryDy=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="callout_play" target="play_box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- hosts line -->
        <mxCell id="hosts_line" value="&lt;font face=&quot;Courier New&quot; color=&quot;#c8d0d8&quot; style=&quot;font-size:12px;&quot;&gt;hosts: &lt;b&gt;&lt;font color=&quot;#ff8800&quot;&gt;nxos&lt;/font&gt;&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="110" y="155" width="140" height="25" as="geometry"/>
        </mxCell>
        <!-- Callout: hosts -->
        <mxCell id="callout_hosts" value="&lt;font style=&quot;font-size:11px;&quot; color=&quot;#ffffff&quot;&gt;Which devices&lt;br&gt;from &lt;b&gt;inventory&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e2d3d;strokeColor=#00aaff;fontSize=11;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="740" y="170" width="140" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_hosts" style="endArrow=block;endFill=1;html=1;strokeWidth=1.5;strokeColor=#00aaff;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="callout_hosts">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="250" y="167" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- gather_facts line -->
        <mxCell id="gather_line" value="&lt;font face=&quot;Courier New&quot; color=&quot;#c8d0d8&quot; style=&quot;font-size:12px;&quot;&gt;gather_facts: &lt;font color=&quot;#ff4444&quot;&gt;false&lt;/font&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="110" y="180" width="180" height="25" as="geometry"/>
