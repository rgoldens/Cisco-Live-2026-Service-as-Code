!! =============================================================================
!! CSR-PE01 — PE Router (West)
!! IOS-XE Startup Configuration
!! Service as Code Lab — Cisco Live 2026
!!
!! NOTE: This config works for both CSR1000v (cisco_csr1000v) and
!!       Catalyst 8000v (cisco_c8000v). Interface names are the same.
!! =============================================================================

hostname csr-pe01

!! --- AAA & Users ---
aaa new-model
aaa authentication login default local
aaa authorization exec default local
!
username admin privilege 15 secret 0 admin
username clab privilege 15 secret 0 clab@123
!

!! --- Services ---
ip ssh version 2
ip scp server enable
!
netconf-yang
netconf-yang feature candidate-datastore
restconf
!

!! --- Loopback ---
interface Loopback0
 description PE01 RID
 ip address 10.0.0.11 255.255.255.255
 ip router isis CORE
!

!! --- Gi2: PE ↔ CE link (toward n9k-ce01) — VRF CUST_A ---
!! This interface will be placed into VRF by Ansible/Terraform at service time.
!! Base config leaves it in global table so the PE boots cleanly.
interface GigabitEthernet2
 description TO_n9k-ce01_Eth1/1
 ip address 10.0.3.1 255.255.255.252
 no shutdown
!

!! --- Gi3: PE ↔ P link (toward xrd01) ---
interface GigabitEthernet3
 description TO_xrd01_Gi0-0-0-1
 ip address 10.0.1.2 255.255.255.252
 ip router isis CORE
 mpls ip
 no shutdown
!

!! --- Gi4: Inter-PE link (toward csr-pe02) ---
interface GigabitEthernet4
 description TO_csr-pe02_Gi4
 ip address 10.0.2.1 255.255.255.252
 ip router isis CORE
 mpls ip
 no shutdown
!

!! --- VRF definitions (skeleton — populated by automation) ---
vrf definition CUST_A
 rd 65000:100
 route-target export 65000:100
 route-target import 65000:100
 !
 address-family ipv4
 exit-address-family
!
vrf definition CUST_B
 rd 65000:200
 route-target export 65000:200
 route-target import 65000:200
 !
 address-family ipv4
 exit-address-family
!

!! --- IS-IS ---
router isis CORE
 net 49.0000.0000.0011.00
 is-type level-2-only
 metric-style wide
 passive-interface Loopback0
!

!! --- MPLS ---
mpls ldp router-id Loopback0 force
!

!! --- BGP ---
router bgp 65000
 bgp router-id 10.0.0.11
 bgp log-neighbor-changes
 no bgp default ipv4-unicast
 !
 !! iBGP to Route Reflectors (xrd01 + xrd02)
 neighbor 10.0.0.1 remote-as 65000
 neighbor 10.0.0.1 description xrd01-RR
 neighbor 10.0.0.1 update-source Loopback0
 neighbor 10.0.0.2 remote-as 65000
 neighbor 10.0.0.2 description xrd02-RR
 neighbor 10.0.0.2 update-source Loopback0
 !
 address-family vpnv4
  neighbor 10.0.0.1 activate
  neighbor 10.0.0.1 send-community both
  neighbor 10.0.0.2 activate
  neighbor 10.0.0.2 send-community both
 exit-address-family
 !
 !! VRF address families — activated by automation when service is provisioned
 address-family ipv4 vrf CUST_A
 exit-address-family
 !
 address-family ipv4 vrf CUST_B
 exit-address-family
!

end
