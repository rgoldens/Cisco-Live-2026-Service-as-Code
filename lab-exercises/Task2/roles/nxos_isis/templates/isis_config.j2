!
! IS-IS Configuration Template for Nexus 9K (N9K as CE)
! Generated by Ansible for Device: {{ inventory_hostname }}
!

! =====================================================================
! IS-IS Instance: {{ isis_instance.name }}
! Area: {{ isis_instance.net }}
! =====================================================================
!
router isis {{ isis_instance.name }}
  net {{ isis_instance.net }}
  is-type {{ isis_instance.level_type }}
  metric-style wide
!

{% for int_name, int_config in interfaces.items() %}
{% if int_config.isis_enabled %}
interface {{ int_name | replace('eth', 'Ethernet') }}
  description {{ int_config.description }}
  ip router isis {{ isis_instance.name }}
{% if int_config.get('isis_level') %}
  isis circuit-type {{ int_config.isis_level }}
{% endif %}
{% if int_config.get('passive') %}
  isis passive
{% endif %}
!
{% endif %}
{% endfor %}

! Configure Loopback
interface loopback0
  description {{ interfaces.loopback0.description }}
  ip router isis {{ isis_instance.name }}
  isis passive
!

! Redistribute connected routes (client subnets)
{% for redis in route_redistribution %}
route-map {{ redis.get('route_map', 'ALLOW_ALL') }} permit 10
  match ip address prefix-list ALLOW_CLIENT_SUBNETS
!
{% endfor %}

router isis {{ isis_instance.name }}
{% for redis in route_redistribution %}
  redistribute {{ redis.protocol }} route-map {{ redis.get('route_map', 'ALLOW_ALL') }}
{% endfor %}
!
