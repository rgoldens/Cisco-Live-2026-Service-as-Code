!
! IS-IS Configuration Template for Cisco IOS XE (CSR as ABR)
! Generated by Ansible for Device: {{ inventory_hostname }}
!
{% for instance in isis_instances.values() %}

! =====================================================================
! IS-IS Instance: {{ instance.name }}
! Area: {{ instance.net }}
! =====================================================================
!
router isis {{ instance.name }}
 net {{ instance.net }}
 is-type {{ instance.level_type }}
 metric-style wide
 !
{% for interface in instance.interfaces %}
 ! Interface: {{ interface.name }}
{% if interface.name == "Loopback0" %}
 passive-interface {{ interface.name }}
{% if interface.get('isis_area') %}
 address-family ipv4 unicast
  multi-topology
 exit-address-family
{% endif %}
{% else %}
 interface {{ interface.name }}
  ip router isis {{ instance.name }}
{% if interface.get('isis_level') == "level-1" %}
  isis circuit-type level-1
{% elif interface.get('isis_level') == "level-2" %}
  isis circuit-type level-2-only
{% endif %}
 exit
{% endif %}
!
{% endfor %}
exit
!
{% endfor %}

! Loopback Interface Configuration
interface Loopback0
{% if loopback.get('isis') %}
 ip router isis CORE
 ip router isis {{ isis_instances.customer.name }}
 passive-interface Loopback0
{% endif %}
exit
!
